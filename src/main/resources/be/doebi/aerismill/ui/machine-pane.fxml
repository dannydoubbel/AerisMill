<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="machineRootPane"
            id="machineRootPane"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="be.doebi.aerismill.ui.MachineController"
            prefWidth="320.0"
            prefHeight="500.0">

    <center>
        <VBox  spacing="8.0">
            <padding>
                <Insets top="8.0" right="8.0" bottom="8.0" left="8.0"/>
            </padding>

            <children>

                <!-- Connection bar -->
                <HBox spacing="8.0" alignment="CENTER_LEFT">
                    <children>
                        <Label text="Port:" />

                        <ComboBox fx:id="portComboBox"
                                  prefWidth="120.0"
                                  HBox.hgrow="NEVER" />

                        <Button fx:id="refreshPortsButton"
                                text="Refresh"
                                onAction="#onRefreshPorts" />

                        <Button fx:id="connectButton"
                                text="Connect"
                                onAction="#onConnectMachine" />

                        <Button fx:id="disconnectButton"
                                text="Disconnect"
                                onAction="#onDisconnectMachine" />
                        <Label text="baud" />

                        <ComboBox fx:id="baudRateComboBox"
                                  prefWidth="140.0"
                                  HBox.hgrow="NEVER" />

                        <Region HBox.hgrow="ALWAYS" />

                        <Label text="Status:" />
                        <Label fx:id="machineStatusLabel"
                               text="Disconnected" />
                    </children>
                </HBox>

                <!-- Resizable main machine sections -->
                <SplitPane fx:id="machineVerticalSplitPane"
                           orientation="VERTICAL"
                           dividerPositions="0.38"
                           VBox.vgrow="ALWAYS">
                    <items>

                        <!-- TOP: Zero / Go To / DRO -->
                        <VBox spacing="10.0">
                            <padding>
                                <Insets top="12.0" right="12.0" bottom="12.0" left="12.0"/>
                            </padding>
                            <children>

                                <Label text="Position Control"
                                       style="-fx-font-size: 16px; -fx-font-weight: bold;" />

                                <GridPane hgap="8.0" vgap="10.0">
                                    <columnConstraints>
                                        <ColumnConstraints percentWidth="20.0" hgrow="ALWAYS"/>
                                        <ColumnConstraints percentWidth="22.0" hgrow="ALWAYS"/>
                                        <ColumnConstraints percentWidth="23.0" hgrow="ALWAYS"/>
                                        <ColumnConstraints percentWidth="35.0" hgrow="ALWAYS"/>
                                    </columnConstraints>

                                    <rowConstraints>
                                        <RowConstraints vgrow="NEVER"/>
                                        <RowConstraints vgrow="NEVER"/>
                                        <RowConstraints vgrow="NEVER"/>
                                    </rowConstraints>

                                    <!-- X -->
                                    <Button text="Go To"
                                            GridPane.rowIndex="0"
                                            GridPane.columnIndex="0"
                                            maxWidth="1.7976931348623157E308"/>
                                    <Button text="Zero X"
                                            GridPane.rowIndex="0"
                                            GridPane.columnIndex="1"
                                            maxWidth="1.7976931348623157E308"/>
                                    <VBox spacing="2.0"
                                          GridPane.rowIndex="0"
                                          GridPane.columnIndex="2">
                                        <children>
                                            <Label fx:id="xMachineLabel"
                                                   text="0.00"
                                                   style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
                                            <Label fx:id="xWorkLabel"
                                                   text="0.00"
                                                   style="-fx-font-size: 12px;"/>
                                        </children>
                                    </VBox>

                                    <!-- Y -->
                                    <Button text="Go To"
                                            GridPane.rowIndex="1"
                                            GridPane.columnIndex="0"
                                            maxWidth="1.7976931348623157E308"/>
                                    <Button text="Zero Y"
                                            GridPane.rowIndex="1"
                                            GridPane.columnIndex="1"
                                            maxWidth="1.7976931348623157E308"/>
                                    <VBox spacing="2.0"
                                          GridPane.rowIndex="1"
                                          GridPane.columnIndex="2">
                                        <children>
                                            <Label fx:id="yMachineLabel"
                                                   text="0.00"
                                                   style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
                                            <Label fx:id="yWorkLabel"
                                                   text="0.00"
                                                   style="-fx-font-size: 12px;"/>
                                        </children>
                                    </VBox>

                                    <!-- Z -->
                                    <Button text="Go To"
                                            onAction="#onGoToPosition"
                                            GridPane.rowIndex="2"
                                            GridPane.columnIndex="0"
                                            maxWidth="1.7976931348623157E308"/>
                                    <Button text="Zero Z"
                                            GridPane.rowIndex="2"
                                            GridPane.columnIndex="1"
                                            maxWidth="1.7976931348623157E308"/>
                                    <VBox spacing="2.0"
                                          GridPane.rowIndex="2"
                                          GridPane.columnIndex="2">
                                        <children>
                                            <Label fx:id="zMachineLabel"
                                                   text="0.00"
                                                   style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
                                            <Label fx:id="zWorkLabel"
                                                   text="0.00"
                                                   style="-fx-font-size: 12px;"/>
                                        </children>
                                    </VBox>

                                    <!-- Right side action buttons -->
                                    <VBox spacing="8.0"
                                          GridPane.rowIndex="0"
                                          GridPane.columnIndex="3"
                                          GridPane.rowSpan="3">
                                        <children>
                                            <Button text="Zero All"
                                                    onAction="#onZeroAll"
                                                    maxWidth="1.7976931348623157E308"/>
                                            <Button text="Go XY0"
                                                    onAction="#onGoXY0"
                                                    maxWidth="1.7976931348623157E308"/>
                                            <Button text="Go To..."
                                                    maxWidth="1.7976931348623157E308"/>
                                            <Region prefHeight="10.0" />
                                            <Button fx:id="homeMachineButton"
                                                    text="Home Machine"
                                                    onAction="#onHomeMachine"
                                                    maxWidth="1.7976931348623157E308"/>
                                            <Region VBox.vgrow="ALWAYS"/>
                                        </children>
                                    </VBox>

                                </GridPane>

                            </children>
                        </VBox>

                        <!-- BOTTOM: Jog / Presets / Move settings -->
                        <VBox spacing="12.0">
                            <padding>
                                <Insets top="12.0" right="12.0" bottom="12.0" left="12.0"/>
                            </padding>
                            <children>

                                <Label text="Jog Control"
                                       style="-fx-font-size: 16px; -fx-font-weight: bold;" />

                                <HBox spacing="16.0" VBox.vgrow="ALWAYS">
                                    <children>

                                        <!-- Jog cluster -->
                                        <GridPane hgap="8.0"
                                                  vgap="8.0"
                                                  HBox.hgrow="ALWAYS">
                                            <columnConstraints>
                                                <ColumnConstraints percentWidth="33.0" hgrow="ALWAYS"/>
                                                <ColumnConstraints percentWidth="34.0" hgrow="ALWAYS"/>
                                                <ColumnConstraints percentWidth="33.0" hgrow="ALWAYS"/>
                                            </columnConstraints>
                                            <rowConstraints>
                                                <RowConstraints percentHeight="25.0" vgrow="ALWAYS"/>
                                                <RowConstraints percentHeight="25.0" vgrow="ALWAYS"/>
                                                <RowConstraints percentHeight="25.0" vgrow="ALWAYS"/>
                                                <RowConstraints percentHeight="25.0" vgrow="ALWAYS"/>
                                            </rowConstraints>

                                            <Button text="Y+"
                                                    onAction="#onJogYPlus"
                                                    GridPane.rowIndex="0"
                                                    GridPane.columnIndex="1"
                                                    maxWidth="1.7976931348623157E308"
                                                    maxHeight="1.7976931348623157E308"/>
                                            <Button text="X-"
                                                    onAction="#onJogXMinus"
                                                    GridPane.rowIndex="1"
                                                    GridPane.columnIndex="0"
                                                    maxWidth="1.7976931348623157E308"
                                                    maxHeight="1.7976931348623157E308"/>
                                            <Button text="Stop"
                                                    onAction="#onStopJog"
                                                    GridPane.rowIndex="1"
                                                    GridPane.columnIndex="1"
                                                    maxWidth="1.7976931348623157E308"
                                                    maxHeight="1.7976931348623157E308"/>
                                            <Button text="X+"
                                                    onAction="#onJogXPlus"
                                                    GridPane.rowIndex="1"
                                                    GridPane.columnIndex="2"
                                                    maxWidth="1.7976931348623157E308"
                                                    maxHeight="1.7976931348623157E308"/>
                                            <Button text="Y-"
                                                    onAction="#onJogYMinus"
                                                    GridPane.rowIndex="2"
                                                    GridPane.columnIndex="1"
                                                    maxWidth="1.7976931348623157E308"
                                                    maxHeight="1.7976931348623157E308"/>

                                            <Button text="Z+"
                                                    onAction="#onJogZPlus"
                                                    GridPane.rowIndex="0"
                                                    GridPane.columnIndex="2"
                                                    maxWidth="1.7976931348623157E308"
                                                    maxHeight="1.7976931348623157E308"/>
                                            <Button text="Z-"
                                                    onAction="#onJogZMinus"
                                                    GridPane.rowIndex="2"
                                                    GridPane.columnIndex="2"
                                                    maxWidth="1.7976931348623157E308"
                                                    maxHeight="1.7976931348623157E308"/>
                                        </GridPane>

                                        <!-- Preset buttons -->
                                        <VBox spacing="10.0" prefWidth="110.0">
                                            <children>
                                                <Button text="Rapid"
                                                        onAction="#onPresetRapid"
                                                        maxWidth="1.7976931348623157E308"/>
                                                <Button text="Normal"
                                                        onAction="#onPresetNormal"
                                                        maxWidth="1.7976931348623157E308"/>
                                                <Button text="Precise"
                                                        onAction="#onPresetPrecise"
                                                        maxWidth="1.7976931348623157E308"/>
                                                <Region VBox.vgrow="ALWAYS"/>
                                            </children>
                                        </VBox>

                                    </children>
                                </HBox>

                                <HBox spacing="8.0" alignment="CENTER_LEFT">
                                    <children>
                                        <Label text="Spindle" />

                                        <Button text="Start"
                                                onAction="#onSpindleStart" />

                                        <Button text="Stop"
                                                onAction="#onSpindleStop" />

                                        <Region HBox.hgrow="ALWAYS" />

                                        <Label text="RPM" />

                                        <Button text="−"
                                                onAction="#onSpindleSpeedDown" />

                                        <TextField fx:id="spindleSpeedField"
                                                   onAction="#onSpindleSpeedFieldChange"
                                                   text="12000"
                                                   prefWidth="80.0" />

                                        <Button text="+"
                                                onAction="#onSpindleSpeedUp" />
                                    </children>
                                </HBox>


                                <Separator />

                                <!-- Bottom settings row -->
                                <GridPane hgap="12.0" vgap="8.0">
                                    <columnConstraints>
                                        <ColumnConstraints percentWidth="33.0" hgrow="ALWAYS"/>
                                        <ColumnConstraints percentWidth="33.0" hgrow="ALWAYS"/>
                                        <ColumnConstraints percentWidth="34.0" hgrow="ALWAYS"/>
                                    </columnConstraints>

                                    <!-- XY move -->
                                    <VBox spacing="4.0" GridPane.columnIndex="0">
                                        <children>
                                            <Label text="XY move (mm)" />
                                            <HBox spacing="4.0">
                                                <children>
                                                    <Button text="−" onAction="#onDecreaseXyMove" maxWidth="1.7976931348623157E308" HBox.hgrow="ALWAYS"/>
                                                    <TextField fx:id="xyMoveField"
                                                               text="5"
                                                               alignment="CENTER"
                                                               prefWidth="70.0" />
                                                    <Button text="+" onAction="#onIncreaseXyMove"  maxWidth="1.7976931348623157E308" HBox.hgrow="ALWAYS"/>
                                                </children>
                                            </HBox>
                                        </children>
                                    </VBox>

                                    <!-- Z move -->
                                    <VBox spacing="4.0" GridPane.columnIndex="1">
                                        <children>
                                            <Label text="Z move (mm)" />
                                            <HBox spacing="4.0">
                                                <children>
                                                    <Button text="−" onAction="#onDecreaseZMove" maxWidth="1.7976931348623157E308" HBox.hgrow="ALWAYS"/>

                                                    <TextField fx:id="zMoveField"
                                                               text="2"
                                                               alignment="CENTER"
                                                               prefWidth="70.0" />

                                                    <Button text="+" onAction="#onIncreaseZMove" maxWidth="1.7976931348623157E308" HBox.hgrow="ALWAYS"/>
                                                </children>
                                            </HBox>
                                        </children>
                                    </VBox>

                                    <!-- Speed -->
                                    <VBox spacing="4.0" GridPane.columnIndex="2">
                                        <children>
                                            <Label text="Speed (mm/min)" />
                                            <HBox spacing="4.0">
                                                <children>
                                                    <Button text="−" onAction="#onDecreaseFeedRate" maxWidth="1.7976931348623157E308" HBox.hgrow="ALWAYS"/>
                                                    <TextField fx:id="feedRateField"
                                                               text="3000"
                                                               alignment="CENTER"
                                                               prefWidth="70" />
                                                    <Button text="+" onAction="#onIncreaseFeedRate" maxWidth="1.7976931348623157E308" HBox.hgrow="ALWAYS"/>
                                                </children>
                                            </HBox>
                                        </children>
                                    </VBox>

                                </GridPane>

                            </children>
                        </VBox>

                    </items>
                </SplitPane>





            </children>
        </VBox>
    </center>

</BorderPane>