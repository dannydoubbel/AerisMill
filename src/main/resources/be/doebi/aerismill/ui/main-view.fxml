<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.SeparatorMenuItem?>

<BorderPane fx:id="rootPane"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="be.doebi.aerismill.ui.MainController"
            prefWidth="1000.0"
            prefHeight="700.0">

    <top>
        <MenuBar>
            <menus>
                <Menu text="File">
                    <items>
                        <MenuItem text="Open STEP..." onAction="#onOpenStepFile"/>
                        <MenuItem text="Open STL (ASCII)..." onAction="#onOpenAsciiStlFile"/>
                        <MenuItem text="Open STL (Binary)..." onAction="#onOpenBinaryStlFile"/>
                        <MenuItem text="Close File" onAction="#onCloseFile"/>
                        <SeparatorMenuItem/>
                        <MenuItem text="Exit" onAction="#onExitApplication"/>
                    </items>
                </Menu>
                <Menu text="Help">
                    <items>
                        <MenuItem text="About" onAction="#onShowAbout"/>
                    </items>
                </Menu>
            </menus>
        </MenuBar>
    </top>

    <center>
        <SplitPane fx:id="work"
                   orientation="VERTICAL"
                   dividerPositions="0.72"
                   minHeight="100.0"
                   minWidth="100.0">
            <items>

                <SplitPane fx:id="mainHorizontalSplitPane"
                           orientation="HORIZONTAL"
                           dividerPositions="0.30"
                           minHeight="0.0"
                           minWidth="0.0">
                    <items>

                        <TabPane fx:id="leftTabPane"
                                 tabClosingPolicy="UNAVAILABLE"
                                 minWidth="260.0"
                                 minHeight="0.0"
                                 prefWidth="320.0">
                            <tabs>
                                <Tab fx:id="machineTab" text="Machine">
                                    <content>
                                        <fx:include fx:id="machinePane" source="machine-pane.fxml"/>
                                    </content>
                                </Tab>

                                <Tab text="Tool">
                                    <content>
                                        <AnchorPane/>
                                    </content>
                                </Tab>

                                <Tab text="Setup">
                                    <content>
                                        <AnchorPane/>
                                    </content>
                                </Tab>
                            </tabs>
                        </TabPane>

                        <SplitPane fx:id="workConsoleSplitPane"
                                   orientation="HORIZONTAL"
                                   dividerPositions="0.72"
                                   minHeight="0.0"
                                   minWidth="100.0">
                            <items>

                                <StackPane fx:id="mainWorkArea"
                                           minWidth="300.0"
                                           minHeight="0.0"/>

                                <VBox fx:id="comConsolePane"
                                      spacing="6"
                                      minWidth="220.0"
                                      minHeight="0.0"
                                      prefWidth="320.0">
                                    <children>

                                        <HBox spacing="4" alignment="CENTER_LEFT" pickOnBounds="false">
                                            <children>
                                                <Label text="COM Console"/>
                                                <Region HBox.hgrow="ALWAYS"/>
                                                <Button text="Clear"
                                                        focusTraversable="false"
                                                        minHeight="22.0"
                                                        prefHeight="22.0"
                                                        onAction="#onClearComConsole"/>
                                                <Button text="Copy"
                                                        focusTraversable="false"
                                                        minHeight="22.0"
                                                        prefHeight="22.0"
                                                        onAction="#onCopyComConsole"/>
                                            </children>
                                        </HBox>

                                        <TextArea fx:id="comConsoleOutput"
                                                  wrapText="true"
                                                  editable="false"
                                                  minHeight="0.0"
                                                  VBox.vgrow="ALWAYS"/>

                                        <HBox minHeight="0.0" spacing="4" alignment="CENTER_LEFT">
                                            <children>
                                                <Label text="Serial send:"/>
                                                <TextField fx:id="textManualSerialSend"
                                                           prefWidth="70.0"
                                                           HBox.hgrow="ALWAYS"/>
                                                <Button fx:id="buttonManualSerialSend"
                                                        text="Send"
                                                        onAction="#onManualSerialSend"/>
                                            </children>
                                        </HBox>

                                    </children>
                                </VBox>

                            </items>
                        </SplitPane>

                    </items>
                </SplitPane>

                <StackPane minHeight="120.0" prefHeight="220.0">
                    <children>
                        <TextArea fx:id="consoleOutput"
                                  id="consoleOutput"
                                  text="console output"
                                  minHeight="0.0"/>
                        <HBox spacing="4"
                              alignment="TOP_RIGHT"
                              pickOnBounds="false"
                              StackPane.alignment="TOP_RIGHT">
                            <children>
                                <Button text="Clear"
                                        focusTraversable="false"
                                        minHeight="22.0"
                                        prefHeight="22.0"
                                        onAction="#onClearConsoleOutput"/>
                                <Button text="Copy"
                                        focusTraversable="false"
                                        minHeight="22.0"
                                        prefHeight="22.0"
                                        onAction="#onCopyConsoleOutput"/>
                            </children>
                        </HBox>
                    </children>
                </StackPane>

            </items>
        </SplitPane>
    </center>

    <bottom>
        <StackPane alignment="CENTER_RIGHT"
                   minHeight="26.0"
                   prefHeight="26.0"
                   maxHeight="26.0">
            <children>
                <TextField fx:id="infoField"
                           id="infoField"
                           minHeight="26.0"
                           prefHeight="26.0"
                           maxHeight="26.0"
                           style="-fx-padding: 0 112 0 6;"/>
                <HBox spacing="4"
                      alignment="CENTER_RIGHT"
                      pickOnBounds="false"
                      StackPane.alignment="CENTER_RIGHT">
                    <children>
                        <Button text="Clear"
                                focusTraversable="false"
                                minHeight="22.0"
                                prefHeight="22.0"
                                onAction="#onClearInfoField"/>
                        <Button text="Copy"
                                focusTraversable="false"
                                minHeight="22.0"
                                prefHeight="22.0"
                                onAction="#onCopyInfoField"/>
                    </children>
                </HBox>
            </children>
        </StackPane>
    </bottom>

</BorderPane>
